# 复制为 .env 并按需填写。.env 绝不提交到仓库（已在 .gitignore）。

# ---- App ----
ENVIRONMENT=development

# ---- PostgreSQL ----
POSTGRES_USER=invoce
POSTGRES_PASSWORD=invoce
POSTGRES_DB=invoce
# 容器内访问用服务名 postgres；本机直连用 localhost
DATABASE_URL=postgresql+asyncpg://invoce:invoce@postgres:5432/invoce

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Auth（生产务必改掉）----
JWT_SECRET=dev-change-me-please-use-a-32char-min-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 用于加密 IMAP 授权码的 Fernet 密钥。生成命令：
#   python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# 下面是一个【仅供本地开发】的全零占位密钥，生产必须替换：
FERNET_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# ---- S3 / R2（必须私有桶）----
S3_ENDPOINT_URL=
S3_REGION=auto
S3_BUCKET=invoce-invoices
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
PRESIGNED_EXPIRE_SECONDS=60

# ---- AIGC 网关 ----
AIGC_BASE_URL=
AIGC_API_KEY=
AIGC_MODEL=qwen3.5-plus

# ---- IMAP ----
IMAP_POLL_INTERVAL_SECONDS=1800

# ---- 前端 ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
